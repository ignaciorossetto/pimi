# Mercado Pago (pagos con retención) — Access Token de PRUEBA primero:
# Panel de MP > Tu negocio > Configuración > Credenciales > Credenciales de prueba.
# El webhook usa NEXT_PUBLIC_SITE_URL para armar notification_url, así que
# en local hace falta un túnel (ngrok/cloudflared) apuntando a :3000 para
# que Mercado Pago pueda llamarlo — localhost no es alcanzable desde afuera.
# Alternativa mientras no lo configurás: activar el "modo de pago de
# prueba" desde /admin, que evita Mercado Pago por completo.
MERCADOPAGO_ACCESS_TOKEN=

# Resend (emails de recordatorio) — https://resend.com, crear API key en
# Dashboard > API Keys. Sin dominio propio verificado podés probar con
# RESEND_FROM_EMAIL=Pimi <onboarding@resend.dev> (solo entrega a tu propio
# email de cuenta de Resend, útil para probar antes de verificar dominio).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pimi <onboarding@resend.dev>

# Cron de recordatorios (app/api/cron/recordatorios) — Vercel setea esta
# env var vos mismo en el proyecto (Project Settings > Environment
# Variables) y Vercel Cron manda automáticamente
# "Authorization: Bearer <CRON_SECRET>" en cada llamada programada. En
# local no hace falta: podés pegarle al endpoint a mano con este mismo
# valor en el header Authorization para probarlo.
CRON_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_QEk1mk1YTu_IWkJoEaGx2A_-M3_Ij6u
